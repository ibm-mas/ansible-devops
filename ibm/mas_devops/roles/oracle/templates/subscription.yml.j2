---
apiVersion: v1
kind: Namespace
metadata:
  name: "{{ oracle_namespace }}"
---
apiVersion: operators.coreos.com/v1
kind: OperatorGroup
metadata:
  name: "{{ oracle_namespace }}"
  namespace: "{{ oracle_namespace }}"
spec:
  targetNamespaces:
    - "{{ oracle_namespace }}"
---
apiVersion: operators.coreos.com/v1alpha1
kind: Subscription
metadata:
  labels:
    operators.coreos.com/oracle-database-operator.oracle: ""
  name: oracle-database-operator
  namespace: "{{ oracle_namespace }}"
spec:
  channel: alpha
  installPlanApproval: Automatic
  name: oracle-database-operator
  source: certified-operators
  sourceNamespace: openshift-marketplace
  startingCSV: oracle-database-operator.v0.2.0