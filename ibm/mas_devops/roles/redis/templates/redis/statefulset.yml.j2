---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: {{ redis_instance_name }}-redis
  namespace: {{ redis_namespace }}
  labels:
    app: redis
    instance: {{ redis_instance_name }}
spec:
  serviceName: {{ redis_replica_service }}
  replicas: {{ redis_replicas }}
  selector:
    matchLabels:
      app: redis
      instance: {{ redis_instance_name }}
  template:
    metadata:
      labels:
        app: redis
        instance: {{ redis_instance_name }}
    spec:
      serviceAccountName: {{ redis_service_account }}
      securityContext:
        runAsNonRoot: true
      initContainers:
        - name: init-redis
          image: {{ redis_image }}
          imagePullPolicy: {{ image_pull_policy }}
          command:
            - bash
            - /init-scripts/init.sh
          env:
            - name: REDIS_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: {{ redis_credentials_secret }}
                  key: password
            - name: SENTINEL_ID_0
              value: "{{ redis_sentinel_id_0 }}"
            - name: SENTINEL_ID_1
              value: "{{ redis_sentinel_id_1 }}"
            - name: SENTINEL_ID_2
              value: "{{ redis_sentinel_id_2 }}"
          volumeMounts:
            - name: init-config
              mountPath: /init-scripts
              readOnly: true
            - name: redis-config
              mountPath: /readonly-config
              readOnly: true
            - name: data
              mountPath: /data
          securityContext:
            allowPrivilegeEscalation: false
            capabilities:
              drop:
                - ALL
            runAsNonRoot: true
            seccompProfile:
              type: RuntimeDefault
      containers:
        - name: redis
          image: {{ redis_image }}
          imagePullPolicy: {{ image_pull_policy }}
          command:
            - redis-server
            - /data/redis.conf
          ports:
            - name: redis
              containerPort: {{ redis_port }}
              protocol: TCP
{% if redis_tls_enabled %}
            - name: redis-tls
              containerPort: {{ redis_tls_port }}
              protocol: TCP
{% endif %}
          env:
            - name: REDIS_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: {{ redis_credentials_secret }}
                  key: password
          livenessProbe:
            exec:
              command:
                - sh
                - -c
                - /probes/readiness.sh {{ redis_port }}
            initialDelaySeconds: 30
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 5
          readinessProbe:
            exec:
              command:
                - sh
                - -c
                - /probes/readiness.sh {{ redis_port }}
            initialDelaySeconds: 15
            periodSeconds: 5
            timeoutSeconds: 3
            failureThreshold: 5
          resources:
            requests:
              cpu: {{ redis_cpu_requests }}
              memory: {{ redis_mem_requests }}
            limits:
              cpu: {{ redis_cpu_limits }}
              memory: {{ redis_mem_limits }}
          volumeMounts:
            - name: data
              mountPath: /data
            - name: probes
              mountPath: /probes
              readOnly: true
{% if redis_tls_enabled %}
            - name: redis-certs
              mountPath: /certs
              readOnly: true
{% endif %}
          securityContext:
            allowPrivilegeEscalation: false
            capabilities:
              drop:
                - ALL
            runAsNonRoot: true
            seccompProfile:
              type: RuntimeDefault
{% if redis_sentinel_enabled %}
        - name: sentinel
          image: {{ redis_image }}
          imagePullPolicy: {{ image_pull_policy }}
          command:
            - redis-server
            - /data/sentinel.conf
            - --sentinel
          ports:
            - name: sentinel
              containerPort: {{ redis_sentinel_port }}
              protocol: TCP
          env:
            - name: REDIS_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: {{ redis_credentials_secret }}
                  key: password
          livenessProbe:
            exec:
              command:
                - sh
                - -c
                - /probes/readiness.sh {{ redis_sentinel_port }}
            initialDelaySeconds: 30
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 5
          readinessProbe:
            exec:
              command:
                - sh
                - -c
                - /probes/readiness.sh {{ redis_sentinel_port }}
            initialDelaySeconds: 15
            periodSeconds: 5
            timeoutSeconds: 3
            failureThreshold: 5
          resources:
            requests:
              cpu: 100m
              memory: 128Mi
            limits:
              cpu: 200m
              memory: 256Mi
          volumeMounts:
            - name: data
              mountPath: /data
            - name: probes
              mountPath: /probes
              readOnly: true
          securityContext:
            allowPrivilegeEscalation: false
            capabilities:
              drop:
                - ALL
            runAsNonRoot: true
            seccompProfile:
              type: RuntimeDefault
{% endif %}
      volumes:
        - name: init-config
          configMap:
            name: {{ redis_instance_name }}-redis-init
            defaultMode: 0755
        - name: redis-config
          configMap:
            name: {{ redis_instance_name }}-redis-config
        - name: probes
          configMap:
            name: {{ redis_instance_name }}-redis-probes
            defaultMode: 0755
{% if redis_tls_enabled %}
        - name: redis-certs
          secret:
            secretName: {{ redis_instance_name }}-tls
{% endif %}
  volumeClaimTemplates:
    - metadata:
        name: data
        labels:
          app: redis
          instance: {{ redis_instance_name }}
      spec:
        accessModes:
          - ReadWriteOnce
        resources:
          requests:
            storage: {{ redis_storage_size }}
{% if redis_storage_class is defined and redis_storage_class != "" %}
        storageClassName: {{ redis_storage_class }}
{% endif %}