---
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ redis_instance_name }}-redis-probes
  namespace: {{ redis_namespace }}
  labels:
    app: redis
    instance: {{ redis_instance_name }}
data:
  readiness.sh: |
    #!/bin/sh
    set -eu
    
    PORT="$1"
    
    # Determine connection type based on port and cert availability
    # Port 6380 = Redis TLS, Port 6379 = Redis non-TLS, Port 26379 = Sentinel non-TLS
    if [ "$PORT" = "6380" ] && [ -d "/certs" ]; then
        # Redis TLS port
        CHECK_SERVER="$(redis-cli -p "$PORT" -a "$REDIS_PASSWORD" --tls --cert /certs/tls.crt --key /certs/tls.key --cacert /certs/ca.crt ping 2>&1)"
    elif [ "$PORT" = "6379" ]; then
        # Redis non-TLS port
        CHECK_SERVER="$(redis-cli -p "$PORT" -a "$REDIS_PASSWORD" ping 2>&1)"
    else
        # Sentinel port (26379) - no auth, no TLS
        CHECK_SERVER="$(redis-cli -p "$PORT" ping 2>&1)"
    fi
    
    # Check if response contains PONG (may have warnings before it)
    if echo "$CHECK_SERVER" | grep -q "PONG"; then
        exit 0
    else
        echo "Server check failed with: $CHECK_SERVER"
        exit 1
    fi