---
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ redis_instance_name }}-redis-config
  namespace: {{ redis_namespace }}
  labels:
    app: redis
    instance: {{ redis_instance_name }}
data:
  redis.conf: |
    # Redis Configuration
    bind 0.0.0.0
    port {{ redis_port }}
    protected-mode yes
    requirepass replace-default-auth
    masterauth replace-default-auth
    
    # Persistence
    save 900 1
    save 300 10
    save 60 10000
    stop-writes-on-bgsave-error yes
    rdbcompression yes
    rdbchecksum yes
    dbfilename dump.rdb
    dir /data
    
    # Replication
    replica-read-only yes
    replica-serve-stale-data yes
    repl-diskless-sync no
    repl-diskless-sync-delay 5
    repl-disable-tcp-nodelay no
    replica-priority 100
    
    # Limits
    maxmemory {{ redis_maxmemory }}
    maxmemory-policy allkeys-lru
    
    # Append Only File
    appendonly yes
    appendfilename "appendonly.aof"
    appendfsync everysec
    no-appendfsync-on-rewrite no
    auto-aof-rewrite-percentage 100
    auto-aof-rewrite-min-size 64mb
    
    # Slow Log
    slowlog-log-slower-than 10000
    slowlog-max-len 128
    
    # Latency Monitor
    latency-monitor-threshold 100
    
    # Event Notification
    notify-keyspace-events ""
    
    # Advanced Config
    hash-max-ziplist-entries 512
    hash-max-ziplist-value 64
    list-max-ziplist-size -2
    list-compress-depth 0
    set-max-intset-entries 512
    zset-max-ziplist-entries 128
    zset-max-ziplist-value 64
    hll-sparse-max-bytes 3000
    stream-node-max-bytes 4096
    stream-node-max-entries 100
    activerehashing yes
    client-output-buffer-limit normal 0 0 0
    client-output-buffer-limit replica 256mb 64mb 60
    client-output-buffer-limit pubsub 32mb 8mb 60
    hz 10
    dynamic-hz yes
    aof-rewrite-incremental-fsync yes
    rdb-save-incremental-fsync yes
{% if redis_tls_enabled %}
    
    # TLS Configuration
    tls-port {{ redis_tls_port }}
    tls-cert-file /certs/tls.crt
    tls-key-file /certs/tls.key
    tls-ca-cert-file /certs/ca.crt
    tls-auth-clients no
    tls-replication yes
{% endif %}

  sentinel.conf: |
    # Sentinel Configuration
    bind 0.0.0.0
    port {{ redis_sentinel_port }}
    sentinel auth-pass mymaster replace-default-auth
    sentinel down-after-milliseconds mymaster {{ redis_sentinel_down_after }}
    sentinel parallel-syncs mymaster {{ redis_sentinel_parallel_syncs }}
    sentinel failover-timeout mymaster {{ redis_sentinel_failover_timeout }}
    sentinel deny-scripts-reconfig yes
    
    # Logging
    logfile ""
    loglevel notice
    