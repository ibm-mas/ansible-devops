apiVersion: networking.istio.io/v1
kind: Gateway
metadata:
  name: {{gateway_name}}
  namespace: {{servicemesh_gateway_namespace}}
spec:
  selector:
    istio: {{gateway_name}}
  servers:
    - hosts:
        - '*.{{mas_domain}}'
      port:
        name: https
        number: 443
        protocol: HTTPS
      tls:
        mode: PASSTHROUGH
