---
apiVersion: mirror.openshift.io/v1alpha2
kind: ImageSetConfiguration
mirror:
{% if mirror_redhat_platform %}
  platform:
    channels:
      - name: stable-{{ ocp_release }}
{% if ocp_min_version != "" %}
        minVersion: {{ ocp_min_version }}
{% endif %}
{% if ocp_max_version != "" %}
        maxVersion: {{ ocp_max_version }}
{% endif %}
{% if ocp_min_version != "" or ocp_max_version != "" %}
        shortestPath: true
{% endif %}
{% endif %}
{% if mirror_redhat_operators %}
  operators:
    # certified-operators
    # -------------------------------------------------------------------------
    - catalog: registry.redhat.io/redhat/certified-operator-index:v{{ ocp_release }}
      packages:
        # Required Packages
        # ---------------------------------------------------------------------
        # Required by ibm.mas_devops.dro role
        - name: ibm-metrics-operator
          channels:
            - name: stable
        # Required by ibm.mas_devops.dro role
        - name: ibm-data-reporter-operator
          channels:
            - name: stable

        # Optional Packages - Visual Inspection
        # ---------------------------------------------------------------------
        # Required by ibm.mas_devops.nvidia_gpu role
        - name: gpu-operator-certified
          defaultChannel: v24.9
          channels:
            - name: v24.9

        # Optional Packages - Turbonomic Integration
        # ---------------------------------------------------------------------
        # Required by ibm.mas_devops.kubeturbo role
        - name: kubeturbo-certified
          channels:
            - name: stable

    # community-operators
    # -------------------------------------------------------------------------
    - catalog: registry.redhat.io/redhat/community-operator-index:v{{ ocp_release }}
      packages:
        # Optional Packages - Grafana
        # ---------------------------------------------------------------------
        #  Required by ibm.mas_devops.grafana role
        - name: grafana-operator
          channels:
            - name: v5
              minVersion: 5.21.2

        # Optional Packages - Kafka
        # ---------------------------------------------------------------------
        #  Required by ibm.mas_devops.kafka role
        - name: strimzi-kafka-operator
          channels:
            - name: strimzi-0.45.x
            - name: stable

    # redhat-operators
    # -------------------------------------------------------------------------
    - catalog: registry.redhat.io/redhat/redhat-operator-index:v{{ ocp_release }}
      packages:
        # Required Packages
        # ---------------------------------------------------------------------
        - name: openshift-pipelines-operator-rh
          channels:
            - name: latest
        - name: openshift-cert-manager-operator
          channels:
            - name: stable-v1

        # Optional Packages - Kafka
        # ---------------------------------------------------------------------
        # Required by ibm.mas_devops.kafka role
        - name: amq-streams
          channels:
            - name: stable

        # Optional Packages - Visual Inspection
        # ---------------------------------------------------------------------
        # Required by ibm.mas_devops.nvidia_gpu role
        - name: nfd
          channels:
            - name: stable

        # Optional Packages - EFS
        # ---------------------------------------------------------------------
        # Required by ibm.mas_devops.ocp_efs role
        - name: aws-efs-csi-driver-operator
          channels:
            - name: stable

        # Optional Packages - ODF
        # ---------------------------------------------------------------------
        # Required by ibm.mas_devops.ocs role
        - name: odf-operator
          channels:
            - name: stable-{{ ocp_release }}
        - name: local-storage-operator
          channels:
            - name: stable
        - name: rook-ceph-operator
          channels:
            - name: stable-{{ ocp_release }}
        - name: recipe
          channels:
            - name: stable-{{ ocp_release }}
        - name: odf-prometheus-operator
          channels:
            - name: stable-{{ ocp_release }}
        - name: odf-external-snapshotter-operator
          channels:
            - name: stable-{{ ocp_release }}
        - name: odf-csi-addons-operator
          channels:
            - name: stable-{{ ocp_release }}
        - name: ocs-operator
          channels:
            - name: stable-{{ ocp_release }}
        - name: ocs-client-operator
          channels:
            - name: stable-{{ ocp_release }}
        - name: mcg-operator
          channels:
            - name: stable-{{ ocp_release }}
        - name: cephcsi-operator
          channels:
            - name: stable-{{ ocp_release }}
{% if ocp_release >= "4.18" %}
        - name: odf-dependencies
          channels:
            - name: stable-{{ ocp_release }}
{% endif %}

        # Optional Packages - AI Service (RHOAI)
        # ---------------------------------------------------------------------
        - name: rhods-operator
          defaultChannel: stable # After 4.19 default channel is stable-3.x
          channels:
            - name: stable
{% if ocp_release >= "4.20" %}
            - name: stable-3.x
{% endif %}

        # Optional Packages - AI Service (ODH)
        # ---------------------------------------------------------------------
{% if ocp_release >= "4.18" %}
        - name: serverless-operator
          channels:
            - name: stable
        - name: servicemeshoperator
          channels:
            - name: stable
        - name: authorino-operator
          channels:
            - name: stable
{% endif %}

        # Optional Packages - SNO
        # ---------------------------------------------------------------------
        # Not used by any of our roles, but often used for SNO installation
        - name: lvms-operator
          channels:
            - name: stable-{{ ocp_release }}

{% endif %}
