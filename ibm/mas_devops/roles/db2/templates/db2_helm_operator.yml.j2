apiVersion: batch/v1
kind: Job
metadata:
  name: {{ db2_instance_name }}-db2-ums-collector-patch-ums
  namespace: {{ db2_namespace }}
  labels:
    helm.sh/chart: db2-ums-collector-1.0.0
    app.kubernetes.io/name: db2-ums-collector
    app.kubernetes.io/instance: {{ db2_instance_name }}
    app.kubernetes.io/version: "1.0.9"
    app.kubernetes.io/managed-by: Helm
  annotations:
    # Run after install and after upgrade
    "helm.sh/hook": post-install,post-upgrade
    "helm.sh/hook-weight": "5"
    "helm.sh/hook-delete-policy": before-hook-creation,hook-succeeded
spec:
  backoffLimit: 3
  activeDeadlineSeconds: 120
  template:
    metadata:
      labels:
        app.kubernetes.io/name: db2-ums-collector
        app.kubernetes.io/instance: {{ db2_instance_name }}
        app.kubernetes.io/component: patch-ums
    spec:
      serviceAccountName: {{ db2_instance_name }}-db2-ums-collector
      restartPolicy: OnFailure
      securityContext:
        runAsNonRoot: true
        seccompProfile:
          type: RuntimeDefault
      containers:
        - name: patch-ums
          image: "cp.stg.icr.io/cp/db2u/db2-operator:1249-x86_64"
          imagePullPolicy: IfNotPresent
          securityContext:
            allowPrivilegeEscalation: false
            capabilities:
              drop:
                - ALL
            readOnlyRootFilesystem: true
          env:
            - name: NAMESPACE
              valueFrom:
                fieldRef:
                  fieldPath: metadata.namespace
            - name: CR_NAME
              value: "ibm-usage-metering-instance"
            - name: SC_ENABLE
              value: "true"
            - name: SC_ENTITLEMENT_KEY_SECRET
              value: "ibm-entitlement-key"
            - name: SC_FREQUENCY
              value: "0 * * * *"
            - name: SC_SANDBOX
              value: "true"
          command:
            - /bin/sh
            - -c
            - |
              set -e

              echo "============================================================"
              echo "Step 1: Patching secret ${SC_ENTITLEMENT_KEY_SECRET} to add token field"
              echo "Namespace: ${NAMESPACE}"
              echo "============================================================"

              # Extract password from .dockerconfigjson
              DOCKER_CONFIG=$(kubectl get secret "${SC_ENTITLEMENT_KEY_SECRET}" -n "${NAMESPACE}" -o jsonpath='{.data.\.dockerconfigjson}' | base64 -d)
              TOKEN=$(echo "$DOCKER_CONFIG" | grep -o '"password":"[^"]*"' | cut -d'"' -f4)
              
              if [ -z "$TOKEN" ]; then
                echo "ERROR: Could not extract password from .dockerconfigjson"
                exit 1
              fi

              # Check if token field already exists
              EXISTING_TOKEN=$(kubectl get secret "${SC_ENTITLEMENT_KEY_SECRET}" -n "${NAMESPACE}" -o jsonpath='{.data.token}' 2>/dev/null || echo "")
              
              if [ -n "$EXISTING_TOKEN" ]; then
                echo "Token field already exists in secret, skipping patch"
              else
                echo "Adding token field to secret..."
                TOKEN_BASE64=$(echo -n "$TOKEN" | base64 -w0)
                kubectl patch secret "${SC_ENTITLEMENT_KEY_SECRET}" -n "${NAMESPACE}" \
                  --type='json' \
                  -p='[{"op":"add","path":"/data/token","value":"'$TOKEN_BASE64'"}]'
                echo "Token field added successfully"
              fi

              echo ""
              echo "============================================================"
              echo "Step 2: Patching IBMUsageMetering CR: ${CR_NAME}"
              echo "Namespace:                    ${NAMESPACE}"
              echo "------------------------------------------------------------"
              echo "softwareCentral.enable:              ${SC_ENABLE}"
              echo "softwareCentral.entitlementKeySecret: ${SC_ENTITLEMENT_KEY_SECRET}"
              echo "softwareCentral.frequency:            ${SC_FREQUENCY}"
              echo "softwareCentral.sandbox:              ${SC_SANDBOX}"
              echo "============================================================"

              PATCH=$(printf '{"spec":{"sender":{"softwareCentral":{"anonymize":false,"enable":%s,"entitlementKeySecret":"%s","frequency":"%s","sandbox":%s}}}}' \
                "${SC_ENABLE}" "${SC_ENTITLEMENT_KEY_SECRET}" "${SC_FREQUENCY}" "${SC_SANDBOX}")

              echo "Applying patch..."
              echo "Command: kubectl patch IBMUsageMetering ${CR_NAME} --namespace ${NAMESPACE} --type merge --patch '${PATCH}'"
              echo ""
              kubectl patch IBMUsageMetering "${CR_NAME}" \
                --namespace "${NAMESPACE}" \
                --type merge \
                --patch "${PATCH}"

              echo ""
              echo "Patch applied successfully. Fetching updated spec.sender.softwareCentral..."
              echo "------------------------------------------------------------"
              kubectl get IBMUsageMetering "${CR_NAME}" \
                --namespace "${NAMESPACE}" \
                -o jsonpath='{.spec.sender.softwareCentral}' \
                | tr ',' '\n' \
                | sed 's/[{}"]//g' \
                | sed 's/^/  /'
              echo ""
              echo "============================================================"
              echo "IBMUsageMetering CR patch complete."
              echo "============================================================"
