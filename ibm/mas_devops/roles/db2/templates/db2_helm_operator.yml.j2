spec:
  schedule: "*/15 * * * *"
  concurrencyPolicy: Forbid
  successfulJobsHistoryLimit: 3
  failedJobsHistoryLimit: 3
  jobTemplate:
    spec:
      ttlSecondsAfterFinished: 1
      backoffLimit: 3
      activeDeadlineSeconds: 600
      template:
        metadata:
          labels:
            app.kubernetes.io/name: db2-ums-collector
            app.kubernetes.io/instance: {{ db2_instance_name }}
        spec:
          serviceAccountName: {{ db2_instance_name }}-db2-ums-collector
          restartPolicy: OnFailure
          securityContext:
            
            runAsNonRoot: true
            seccompProfile:
              type: RuntimeDefault
          containers:
          - name: collector
            image: "cp.stg.icr.io/cp/db2u/db2-operator:1249-x86_64"
            imagePullPolicy: IfNotPresent
            # Explicitly specify command and args since we don't control the entrypoint
            # The app is installed in /db2-ums-collector directory
            command: ["python3.11"]
            args: ["-u", "/db2-ums-collector/main.py"]
            securityContext:
              allowPrivilegeEscalation: false
              capabilities:
                drop:
                - ALL
              readOnlyRootFilesystem: true
            env:
            - name: PYTHONPATH
              value: "/db2-ums-collector"
            - name: LOG_LEVEL
              value: "INFO"
            - name: METRICS_CONFIG
              value: "/config/metrics.yaml"
            - name: UMS_CONFIG_PATH
              value: "/ums-config/url"
            - name: UMS_TOKEN_PATH
              value: "/ums-token/token"
            - name: UMS_CERT_PATH
              value: "/ums-config/tls.crt"
            - name: STATE_FILE
              value: "/tmp/metrics-state.yaml"
            - name: USE_K8S_STATE
              value: "true"
            - name: STATE_CONFIGMAP_NAME
              value: "db2-ums-collector-state"
            - name: POD_NAMESPACE
              valueFrom:
                fieldRef:
                  fieldPath: metadata.namespace
            - name: GENERATE_UMS_CRS
              value: "true"
            - name: UMS_CR_NAMESPACE
              value: "{{ db2_namespace }}"
            volumeMounts:
            - name: metrics-config
              mountPath: /config
              readOnly: true
            - name: ums-config
              mountPath: /ums-config
              readOnly: true
            - name: ums-token
              mountPath: /ums-token
              readOnly: true
            - name: tmp
              mountPath: /tmp
            resources:
              limits:
                cpu: 500m
                memory: 512Mi
              requests:
                cpu: 100m
                memory: 128Mi
          volumes:
          - name: metrics-config
            configMap:
              name: db2-ums-metrics-config
          - name: ums-config
