# Source: db2-operator-standalone/charts/db2-ums-collector/templates/configmap-metrics.yaml
apiVersion: v1
kind: ConfigMap
metadata:
  name: db2-ums-metrics-config
  namespace: {{ db2_namespace }}
  labels:
    helm.sh/chart: db2-ums-collector-1.0.0
    app.kubernetes.io/name: db2-ums-collector
    app.kubernetes.io/instance: {{ db2_instance_name }}
    app.kubernetes.io/version: "1.0.9"
    app.kubernetes.io/managed-by: Helm
data:
  metrics.yaml: |
    metrics:
      - name: INSTANCE_COUNT
        enabled: true
        frequency: 15min
        type: cr
        collector:
          type: db2u_cr
          cr_group: db2u.databases.ibm.com
          cr_version: v1
          cr_types:
            - cr_plural: db2uinstances
              mapping:
                available_cpu: spec.podTemplate.db2u.resource.db2u.limits.cpu
                available_memory: spec.podTemplate.db2u.resource.db2u.limits.memory
                db2_home: /home/db2inst1/sqllib
                db2_numnodes: spec.environment.partitionConfig.total
                db2instance: db2inst1
                db2level: ""
                db2nodes: ""
                db2ptf: ""
                deployments_type: spec.environment.dbType
                distros: ""
                host: ""
                license_type: metadata.annotations.productMetric
                machine: ""
                os: ""
                osbitness: ""
                storage_class_name: spec.storage[2].spec.storageClassName
                version: spec.version
            - cr_plural: db2uclusters
              mapping:
                available_cpu: spec.podConfig.db2u.resource.db2u.limits.cpu
                available_memory: spec.podConfig.db2u.resource.db2u.limits.memory
                databaseName: spec.environment.database.name
                db2level: ""
                deployments_type: spec.environment.dbType
                license_type: spec.license.accept
                size: spec.size
                state: status.state
                version: spec.version
        ums:
          mappingId: db2
          metricType: ADOPTION
          processing: LAST
          productId: .metadata.annotations.productID
          productName: .metadata.annotations.productName
          repeat: true
        breakdowns:
          - groupBy:
            - deployments_type
            - license_type
            - db2level
            - version
            - available_cpu
            - available_memory
            - os
            - distros
            - machine
            - host
            - db2ptf
            - osbitness
            - db2_home
            - db2nodes
            - db2_numnodes
            - db2instance
            - storage_class_name
            name: INSTANCE_COUNT
            source: metricQuantity
      - name: DB2_CUSTOM_METRIC
        enabled: false
        frequency: 2min
        type: rest
        collector:
          base_url: https://www.random.org
          endpoint: /integers/?num=1&min=1&max=100&col=1&base=10&format=plain&rnd=new
          headers:
            User-Agent: DB2-UMS-Collector/1.0
          method: GET
          timeout: 30
          type: rest_api
        mapping:
          metricQuantity: value
          cr_group: db2u.databases.ibm.com
          cr_version: v1
          cr_types:
            - cr_plural: db2uinstances
              mapping:
                available_cpu: spec.podTemplate.db2u.resource.db2u.limits.cpu
                available_memory: spec.podTemplate.db2u.resource.db2u.limits.memory
                db2_home: /home/db2inst1/sqllib
                db2_numnodes: spec.environment.partitionConfig.total
                db2instance: db2inst1
                db2level: ""
                db2nodes: ""
                db2ptf: ""
                deployments_type: spec.environment.dbType
                distros: ""
                host: ""
                license_type: metadata.annotations.productMetric
                machine: ""
                os: ""
                osbitness: ""
                storage_class_name: spec.storage[2].spec.storageClassName
                version: spec.version
            - cr_plural: db2uclusters
              mapping:
                available_cpu: spec.podConfig.db2u.resource.db2u.limits.cpu
                available_memory: spec.podConfig.db2u.resource.db2u.limits.memory
                databaseName: spec.environment.database.name
                db2level: ""
                deployments_type: spec.environment.dbType
                license_type: spec.license.accept
                size: spec.size
                state: status.state
                version: spec.version
        ums:
          mappingId: db2
          metricType: ADOPTION
          processing: ADD
          productId: .metadata.annotations.productID
          productName: .metadata.annotations.productName
          repeat: true
        breakdowns:
          - groupBy:
            - deployments_type
            - license_type
            - db2level
            - version
            - is_containerized
            - state
            name: DB2_CUSTOM_METRIC
            source: metricQuantity

