                            items:
                              description: Array of breakdown quantities for certain groups/tenants.
                              properties:
                                group:
                                  description: Breakdown group/tenant (potentially multidimensional) grouping key.
                                  type: object
                                  x-kubernetes-preserve-unknown-fields: true
                                metricQuantity:
                                  description: |-
                                    Breakdown quantity for the specific group/tenant.
                                    It needs to be provided by JSON payload if not defined in the CR and processing is not set to COUNT.
                                  format: int64
                                  maximum: 999999999
                                  minimum: 0
                                  type: integer
                              required:
                                - group
