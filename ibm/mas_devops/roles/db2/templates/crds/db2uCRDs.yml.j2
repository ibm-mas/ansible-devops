                      pattern: ^.{1,255}$
                      type: string
                  type: object
                  x-kubernetes-preserve-unknown-fields: true
                mappingId:
                  description: |-
                    Mapping key used for augmenting JSON payload with the static data provided by the CR.
                    If the mappingId is provided, the payload is merged with the data defined
                    in the CR with the corresponding mappingId (CR data takes precedence).
                    If the (potentially modified by the CR) payload follows the specific format,
                    then the additional processing is applied (some level of persistency is added).
                    In any case, the raw data is passed-through to the IBM Software Central.
                    Different mappingIds reporting the same metric for the same component should
                    define consistent processing, otherwise the payload with processing different than already
                    received previously will be treated as invalid and not processed.
                    The component is identified by (instanceId, productId) pair.
                    If mappingId is provided, then method field and sources section should not be defined.
                    If mappingId is not provided, the metrics is not being reported by a component,
                    but rather it's being calculated based on other metrics reported to UMS. In such case,
                    method field and sources section needs to be specified.
                  pattern: ^[a-zA-Z0-9_-]{1,128}$
                  type: string
                method:
                  description: |-
                    Optional method for calculating a new metric based on other metrics present in UMS.
                    If this field is set, the mappingId field must not be provided, and the sources section must be specified.
                    Supported methods:
                      - "RATIO_SUM": sums all metrics referenced in the sources section, applying the specified ratios.
                      - "RATIO_SUM_STEPWISE": performs a stepwise ratio-based summation of the referenced metrics.
                    Defaults to "RATIO_SUM" if not specified.
                  type: string
