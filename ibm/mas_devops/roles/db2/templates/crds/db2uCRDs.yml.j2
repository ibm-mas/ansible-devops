                        description: Usage metric breakdown.
                        properties:
                          breakdownBy:
                            description: |-
                              Type of the breakdown groups/tenants provided in the metricBreakdown array -
                              this field is required if metricBreakdown is provided.
                            type: object
                            x-kubernetes-preserve-unknown-fields: true
