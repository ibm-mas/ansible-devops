#!/bin/bash
# MongoDB Index Restore Script
# =============================================================================
# This script restores MongoDB indexes from a JSON backup file
# Generated by Ansible template

set -e  # Exit on error
set -o pipefail  # Exit on pipe failure

# Variables
MONGODB_URI="{{ mongodb_uri }}"
INDEX_FILE_PATH="{{ atlas_index_file_path }}"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Logging functions
log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1" >&2
}

log_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

# Main restore function
restore_indexes() {
    log_info "Starting MongoDB index restore..."
    log_info "Index file: ${INDEX_FILE_PATH}"
    
    # Restore indexes for each database and collection
    log_info "Restoring indexes..."
    
{% for db_name, collections in index_data.items() %}
{% for collection_name, indexes in collections.items() %}
    # Restore indexes for {{ db_name }}.{{ collection_name }}
    log_info "Processing {{ db_name }}.{{ collection_name }}..."
    
    mongosh "${MONGODB_URI}" --eval '
    db = db.getSiblingDB("{{ db_name }}");
{% for index in indexes %}
{% if index.name != "_id_" %}
    try {
        db.{{ collection_name }}.createIndex(
            {{ index.key | to_json }},
            {
                name: "{{ index.name }}"
{% if index.unique is defined and index.unique %}
                , unique: true
{% endif %}
            }
        );
        print("✓ Created index {{ index.name }} on {{ db_name }}.{{ collection_name }}");
    } catch (e) {
        if (e.code === 85 || e.codeName === "IndexOptionsConflict" || e.message.includes("already exists")) {
            print("⚠ Index {{ index.name }} already exists on {{ db_name }}.{{ collection_name }}");
        } else {
            print("✗ Failed to create index {{ index.name }} on {{ db_name }}.{{ collection_name }}: " + e.message);
            throw e;
        }
    }
{% endif %}
{% endfor %}
    ' || {
        log_error "Failed to restore indexes for {{ db_name }}.{{ collection_name }}"
        return 1
    }
    
{% endfor %}
{% endfor %}
    
    log_info "Index restore completed successfully"
    return 0
}

# Execute restore
restore_indexes
exit_code=$?

if [ ${exit_code} -eq 0 ]; then
    log_info "=========================================="
    log_info "MongoDB Index Restore Completed"
    log_info "=========================================="
else
    log_error "=========================================="
    log_error "MongoDB Index Restore Failed"
    log_error "=========================================="
fi

exit ${exit_code}