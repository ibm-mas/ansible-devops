#!/bin/bash
# MongoDB Database Restore Script
# =============================================================================
# This script restores MongoDB data from local backup files to MongoDB Atlas
# Generated by Ansible template

set -e  # Exit on error
set -o pipefail  # Exit on pipe failure

# Variables
MONGODB_URI="{{ mongodb_uri }}"
BACKUP_EXTRACT_DIR="{{ backup_extract_dir }}"
MONGORESTORE_OPTIONS="{{ mongorestore_options }}"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Logging functions
log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1" >&2
}

log_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

# Main restore function
restore_database() {
    log_info "Starting MongoDB database restore..."
    log_info "Backup directory: ${BACKUP_EXTRACT_DIR}"
    
    # Check if backup directory exists
    if [ ! -d "${BACKUP_EXTRACT_DIR}" ]; then
        log_error "Backup directory does not exist: ${BACKUP_EXTRACT_DIR}"
        exit 1
    fi
    
    # Execute mongorestore
    log_info "Executing mongorestore command..."
    mongorestore \
        --uri="${MONGODB_URI}" \
        --authenticationDatabase=admin \
        ${MONGORESTORE_OPTIONS} \
        --drop "${BACKUP_EXTRACT_DIR}/";
    restore_rc=$?
    if [ $restore_rc -eq 0 ]; then
        log_info "Database restore completed successfully"
        return 0
    else
        log_error "Database restore failed"
        return 1
    fi
}

# Execute restore
restore_database
exit_code=$?

if [ ${exit_code} -eq 0 ]; then
    log_info "=========================================="
    log_info "MongoDB Database Restore Completed"
    log_info "=========================================="
else
    log_error "=========================================="
    log_error "MongoDB Database Restore Failed"
    log_error "=========================================="
fi

exit ${exit_code}