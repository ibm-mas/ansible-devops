---
apiVersion: v1
kind: Secret
type: Opaque
metadata:
  name: "{{ mas_instance_id }}-kafka-{{ mas_app_id }}"
  namespace: "{{ manage_namespace }}"
  labels:
    mas.ibm.com/instanceId: "{{ mas_instance_id }}"
    mas.ibm.com/applicationId: "{{ mas_app_id }}"
    app.kubernetes.io/instance: "{{ mas_instance_id }}"
    app.kubernetes.io/managed-by: "suite_manage_kafkaimageprocessor_config"
data:
  certificates: {{ kafka_certificates | b64encode }}
  saslmechanism: {{ kafka_saslmechanism | b64encode }}
  password: "{{ kafka_password | b64encode }}"
  username: "{{ kafka_username | b64encode }}"