---
# Example ExternalSecret for username/password credentials
# This syncs username/password credentials from IBM Secrets Manager
apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: example-credentials-secret
  namespace: my-namespace
spec:
  refreshInterval: 1h
  secretStoreRef:
    name: ibm-secrets-manager
    kind: ClusterSecretStore
  target:
    name: database-credentials
    creationPolicy: Owner
  dataFrom:
    - extract:
        key: my-credentials-secret-id  # IBM Secrets Manager secret ID for username_password type