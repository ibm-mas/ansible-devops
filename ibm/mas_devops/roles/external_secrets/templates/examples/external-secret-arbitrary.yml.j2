---
# Example ExternalSecret for arbitrary secrets (key-value pairs)
# This syncs a secret from IBM Secrets Manager into a Kubernetes secret
apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: example-arbitrary-secret
  namespace: my-namespace
spec:
  refreshInterval: 1h
  secretStoreRef:
    name: ibm-secrets-manager
    kind: ClusterSecretStore
  target:
    name: my-kubernetes-secret
    creationPolicy: Owner
  data:
    - secretKey: username
      remoteRef:
        key: my-secret-id  # IBM Secrets Manager secret ID
        property: username
    - secretKey: password
      remoteRef:
        key: my-secret-id
        property: password